---
import Layout from '../layouts/Layout.astro';
import {
  SESSION_COOKIE,
  SESSION_MAX_AGE,
  createSession,
  createUser,
  getUserByEmail,
} from '../lib/auth';

if (Astro.locals.user) return Astro.redirect('/dashboard');

let error = '';
const values = { name: '', email: '' };

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const name = String(form.get('name') ?? '').trim();
  const email = String(form.get('email') ?? '').trim();
  const password = String(form.get('password') ?? '');
  const confirm = String(form.get('confirm') ?? '');
  values.name = name;
  values.email = email;

  if (!name || !email || !password) {
    error = '모든 항목을 입력해 주세요.';
  } else if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
    error = '올바른 이메일 형식이 아닙니다.';
  } else if (password.length < 6) {
    error = '비밀번호는 최소 6자 이상이어야 합니다.';
  } else if (password !== confirm) {
    error = '비밀번호가 일치하지 않습니다.';
  } else if (getUserByEmail(email)) {
    error = '이미 등록된 이메일입니다.';
  } else {
    const user = createUser(email, name, password);
    const session = createSession(user.id);
    Astro.cookies.set(SESSION_COOKIE, session.id, {
      httpOnly: true,
      sameSite: 'lax',
      path: '/',
      maxAge: SESSION_MAX_AGE,
    });
    return Astro.redirect('/dashboard');
  }
}
---

<Layout title="회원가입 · EnglishEdu">
  <h1>회원가입</h1>
  <div class="card">
    {error && <div class="alert alert-error">{error}</div>}
    <form method="POST">
      <label for="name">이름</label>
      <input id="name" name="name" type="text" value={values.name} autocomplete="name" required />

      <label for="email">이메일</label>
      <input id="email" name="email" type="email" value={values.email} autocomplete="email" required />

      <label for="password">비밀번호 (6자 이상)</label>
      <input id="password" name="password" type="password" autocomplete="new-password" required />

      <label for="confirm">비밀번호 확인</label>
      <input id="confirm" name="confirm" type="password" autocomplete="new-password" required />

      <button type="submit">계정 만들기</button>
    </form>
  </div>
  <p class="muted">이미 계정이 있으신가요? <a href="/login">로그인</a></p>
</Layout>
